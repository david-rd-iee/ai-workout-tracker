rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGreekStatueAdmin() {
      return isSignedIn() && request.auth.token.email == 'dev-account@example.com';
    }

    function isGroupOwner(groupId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/groupID/$(groupId))
        && firestore.get(/databases/(default)/documents/groupID/$(groupId)).data.ownerUserId == request.auth.uid;
    }

    function isAssignedTrainerPair(clientId, trainerId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(clientId))
        && firestore.get(/databases/(default)/documents/users/$(clientId)).data.trainerId == trainerId;
    }

    // Profile pictures uploaded from profile page
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Existing client profile image upload path
    match /client-images/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Group images uploaded from group settings page
    match /group-images/{groupId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isGroupOwner(groupId);
    }

    // Greek statue admin uploads
    match /GreekStatues/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isGreekStatueAdmin();
    }

    // Recorded workout analysis videos + JSON artifacts
    match /trainers/{trainerId}/clients/{clientId}/videoAnalysis/{allPaths=**} {
      allow read: if isSignedIn() && (
        request.auth.uid == trainerId ||
        request.auth.uid == clientId
      );

      allow write: if isSignedIn() && (
        request.auth.uid == trainerId ||
        (request.auth.uid == clientId && isAssignedTrainerPair(clientId, trainerId))
      );
    }

    // Trainer-client agreements and client signatures
    match /agreements/{clientId}/{allPaths=**} {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId ||
        isAssignedTrainerPair(clientId, request.auth.uid)
      );

      allow write: if isSignedIn() && (
        request.auth.uid == clientId ||
        isAssignedTrainerPair(clientId, request.auth.uid)
      );
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

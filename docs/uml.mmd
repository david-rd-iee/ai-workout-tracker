classDiagram
direction LR

namespace Frontend_Pages {
  class WorkoutChatbotPage
  class WorkoutHistoryPage
  class WorkoutHistoryCsvPage
  class WorkoutSummaryPage
  class ChatDetailPage
}

namespace Frontend_Services {
  class WorkoutWorkflowService
  class WorkoutLogService
  class WorkoutSummaryService
  class WorkoutChatService
  class WorkoutSessionFormatterService
  class WorkoutWorkflowSummaryProjectionService
  class WorkoutWorkflowEstimatorPreparationService
  class ChatsService
}

namespace Backend_Functions {
  class CompleteWorkoutEventCallable
  class WorkoutEventPostWriteHandlers
}

namespace Shared_Domain {
  class WorkoutEvent {
    +date: string
    +entries: WorkoutEventEntry[]
    +summary: WorkoutEventSummary
    +source: WorkoutEventSource
  }

  class WorkoutEventSummary {
    +estimatedCalories: number
    +trainerNotes: string
    +isComplete: boolean
  }

  class WorkoutEventEntry {
    +kind: strength/cardio/other
    +estimatedCalories: number
  }

  class WorkoutEventRecord {
    +schemaVersion: 1
    +event: WorkoutEvent
    +submissionMetadata: localSubmittedDate + localSubmittedHour
    +createdAt: timestamp
    +updatedAt: timestamp
  }

  class WorkoutSummary {
    +date: string
    +workoutEventIds: string[]
    +eventCount: number
    +aggregate: WorkoutEvent
    +firstEventCreatedAt: ISO string
    +lastEventCreatedAt: ISO string
  }
}

namespace Legacy_UI_View_Model {
  class WorkoutSessionPerformance {
    +date: string
    +trainingRows: WorkoutTrainingRow[]
    +strengthTrainingRow: WorkoutTrainingRow[]
    +cardioTrainingRow: CardioTrainingRow[]
    +otherTrainingRow: OtherTrainingRow[]
    +estimated_calories: number
    +trainer_notes: string
    +isComplete: boolean
  }

  class WorkoutTrainingRow
  class CardioTrainingRow
  class OtherTrainingRow
}

namespace Firebase_Data {
  class UserWorkoutEventsCollection {
    +users/{uid}/workoutEvents/{eventId}
  }

  class UserWorkoutSummariesCollection {
    +users/{uid}/workoutSummaries/{YYYY-MM-DD}
  }

  class DirectChatMessage {
    +chats/{chatId}/messages/workout_summary_{YYYY-MM-DD}
    +type: workout_summary
  }
}

namespace Infrastructure {
  class Firestore
  class RealtimeDatabase
  class OpenAI
}

WorkoutEvent o-- WorkoutEventSummary
WorkoutEvent o-- WorkoutEventEntry
WorkoutEventRecord o-- WorkoutEvent
WorkoutSummary o-- WorkoutEvent : aggregate
WorkoutSessionPerformance o-- WorkoutTrainingRow
WorkoutSessionPerformance o-- CardioTrainingRow
WorkoutSessionPerformance o-- OtherTrainingRow

WorkoutChatbotPage --> WorkoutWorkflowService : processWorkoutMessage()/submitWorkout()
WorkoutHistoryPage --> WorkoutSummaryService : listRecentWorkoutSummaries()
WorkoutHistoryCsvPage --> WorkoutHistoryPage : consumes grouped daily summaries
WorkoutSummaryPage --> WorkoutSummaryService : getWorkoutSummary(date)
ChatDetailPage --> ChatsService : subscribes to direct chat

WorkoutWorkflowService --> WorkoutChatService : sendMessage()
WorkoutWorkflowService --> WorkoutLogService : saveCompletedWorkout()
WorkoutWorkflowService --> WorkoutSessionFormatterService : normalize/apply notes
WorkoutWorkflowService --> WorkoutWorkflowSummaryProjectionService : project workflow state
WorkoutWorkflowService --> WorkoutWorkflowEstimatorPreparationService : prepare estimator ids

WorkoutSummaryService --> WorkoutSummary : normalize/read daily summaries
WorkoutSummaryService --> WorkoutSessionPerformance : project summary/history UI

WorkoutLogService --> CompleteWorkoutEventCallable : completeWorkoutEvent()
WorkoutLogService --> Firestore : wait for derivations/workout_summary

CompleteWorkoutEventCallable --> UserWorkoutEventsCollection : write canonical WorkoutEventRecord
WorkoutEventPostWriteHandlers --> UserWorkoutSummariesCollection : upsert daily WorkoutSummary
WorkoutEventPostWriteHandlers --> RealtimeDatabase : create or update daily trainer chat message
WorkoutEventPostWriteHandlers --> Firestore : resolve trainerId, user name, stats, scores

UserWorkoutEventsCollection --> Firestore
UserWorkoutSummariesCollection --> Firestore
DirectChatMessage --> RealtimeDatabase
WorkoutChatService --> OpenAI

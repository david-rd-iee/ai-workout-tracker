classDiagram
direction LR

namespace Frontend_Pages {
  class WorkoutChatbotPage
  class WorkoutHistoryPage
  class WorkoutSummaryPage
  class LeaderboardPage
  class ClientChatsPage
  class ChatDetailPage
}

namespace Frontend_Services {
  class WorkoutWorkflowService
  class WorkoutLogService
  class WorkoutSummaryService
  class WorkoutChatService
  class WorkoutWorkflowSummaryProjectionService
  class WorkoutWorkflowEstimatorPreparationService
  class GroupService
  class ChatsService
  class UserService
  class NotificationService
}

namespace Backend_Functions {
  class workoutChatCallable
  class completeWorkoutEvent
  class onWorkoutEventCreated
  class onGroupDocumentWrittenSyncChat
  class ensureGroupChatForGroup
}

namespace Shared_Domain {
  class WorkoutEvent {
    +date: string
    +entries: WorkoutEventEntry[]
    +summary: WorkoutEventSummary
    +source: WorkoutEventSource
  }
  class WorkoutEventSummary {
    +estimatedCalories: number
    +trainerNotes: string
    +isComplete: boolean
  }
  class WorkoutEventEntry {
    +kind: strength/cardio/other
    +estimatedCalories: number
  }
  class WorkoutSummary {
    +date: string
    +workoutEventIds: string[]
    +eventCount: number
    +aggregate: WorkoutEvent
  }
  class WorkoutSessionPerformance {
    +date: string
    +trainingRows: WorkoutTrainingRow[]
    +strengthTrainingRow: WorkoutTrainingRow[]
    +cardioTrainingRow: CardioTrainingRow[]
    +otherTrainingRow: OtherTrainingRow[]
    +estimated_calories: number
    +trainer_notes: string
  }
  class Group {
    +groupId: string
    +name: string
    +isPTGroup: boolean
    +ownerUserId: string
    +userIDs: string[]
    +groupImage: string
  }
  class Chat {
    +chatId: string
    +participants: string[]
    +type: direct_or_group
    +groupId: string
    +displayName: string
    +groupImage: string
  }
  class Message {
    +type: message_kind
    +senderId: string
    +timestamp: string
    +read: boolean
  }
}

namespace Firebase_Data {
  class UserWorkoutEventsCollection {
    +path: users_uid_workoutEvents_eventId
  }
  class UserWorkoutSummariesCollection {
    +path: users_uid_workoutSummaries_date
  }
  class GroupsCollection {
    +path: groupID_groupId
  }
  class ChatsCollection {
    +path: chats_chatId
    +messagesPath: chats_chatId_messages_messageId
  }
  class UserChatsIndex {
    +path: userChats_uid_chatId_true
  }
}

namespace Infrastructure {
  class Firestore
  class RealtimeDatabase
  class OpenAI
}

WorkoutEvent o-- WorkoutEventSummary
WorkoutEvent o-- WorkoutEventEntry
WorkoutSummary o-- WorkoutEvent : aggregate
Chat o-- Message

WorkoutChatbotPage --> WorkoutWorkflowService : processWorkoutMessage()/submitWorkout()
WorkoutHistoryPage --> WorkoutSummaryService : listRecentWorkoutSummaries()
WorkoutSummaryPage --> WorkoutSummaryService : getWorkoutSummary(date)
WorkoutSummaryPage --> GroupService : getUserGroups(uid)
WorkoutSummaryPage --> ChatsService : ensureGroupChatForGroup() + sendWorkoutSummaryMessage()
LeaderboardPage --> ChatsService : ensureGroupChatForGroup()
ClientChatsPage --> ChatsService : initializeUserChats()
ChatDetailPage --> RealtimeDatabase : subscribe chats/{chatId}/messages
ChatDetailPage --> Firestore : read groupID metadata/member list

WorkoutWorkflowService --> WorkoutChatService : sendMessage()
WorkoutWorkflowService --> WorkoutLogService : saveCompletedWorkout()
WorkoutWorkflowService --> WorkoutWorkflowSummaryProjectionService : project workflow state
WorkoutWorkflowService --> WorkoutWorkflowEstimatorPreparationService : prepare estimator ids

WorkoutChatService --> workoutChatCallable : httpsCallable
workoutChatCallable --> OpenAI

WorkoutLogService --> completeWorkoutEvent : httpsCallable
completeWorkoutEvent --> UserWorkoutEventsCollection : write canonical event record
onWorkoutEventCreated --> UserWorkoutSummariesCollection : upsert daily WorkoutSummary
onWorkoutEventCreated --> ChatsCollection : create/update trainer workout_summary message
onWorkoutEventCreated --> Firestore : user stats + score derivations + group war scoring

onGroupDocumentWrittenSyncChat --> GroupsCollection : trigger on create/update
onGroupDocumentWrittenSyncChat --> ChatsCollection : upsert group chat metadata + participants
onGroupDocumentWrittenSyncChat --> UserChatsIndex : add/remove membership pointers

ChatsService --> ensureGroupChatForGroup : httpsCallable(us-central1)
ensureGroupChatForGroup --> GroupsCollection : validate group + membership + PT exclusion
ensureGroupChatForGroup --> ChatsCollection : create or sync group chat
ensureGroupChatForGroup --> UserChatsIndex : ensure caller chat pointer

ChatsService --> RealtimeDatabase : send/read chat messages
ChatsService --> UserService : resolve recipient account type + sender identity
ChatsService --> NotificationService : push notifications

UserWorkoutEventsCollection --> Firestore
UserWorkoutSummariesCollection --> Firestore
GroupsCollection --> Firestore
ChatsCollection --> RealtimeDatabase
UserChatsIndex --> RealtimeDatabase
